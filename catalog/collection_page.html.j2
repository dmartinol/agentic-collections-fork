<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Red Hat Agentic Catalog</title>
    <link rel="stylesheet" href="../styles.css?v=21">
    <style>
        .collection-back { margin-bottom: 1.5rem; }
        .collection-content { max-width: 900px; margin: 0 auto; padding: 0 1rem 2rem; }
        .collection-content h1 { margin-top: 0; }
        .collection-content h2 { margin-top: 2rem; border-bottom: 1px solid var(--border, #e5e5e5); padding-bottom: 0.5rem; }
        .collection-content h3 { margin-top: 1.5rem; }
        .collection-content pre { background: var(--bg-code, #f5f5f5); padding: 1rem; border-radius: var(--radius, 8px); overflow-x: auto; }
        .collection-content code { background: var(--bg-code, #f5f5f5); padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }
        .collection-content pre code { padding: 0; background: none; }
        .collection-content ul, .collection-content ol { margin: 0.5rem 0 1rem 1.5rem; }
        .collection-content a { color: var(--primary, #ee0000); }
        .collection-tabs { display: flex; gap: 0; border-bottom: 2px solid var(--border, #e5e5e5); margin: 1.5rem 0 0; }
        .collection-tab { padding: 0.75rem 1.5rem; font-weight: 600; font-size: 0.95rem; color: var(--text-secondary); cursor: pointer; border: none; background: none; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.2s ease; }
        .collection-tab:hover { color: var(--primary); }
        .collection-tab.active { color: var(--primary); border-bottom-color: var(--primary); }
        .collection-tab-panel { display: none; padding: 1.5rem 0; }
        .collection-tab-panel.active { display: block; }
        .install-accordion { margin-top: 1rem; }
        .install-accordion-item { border: 1px solid var(--border, #e5e5e5); border-radius: var(--radius, 8px); margin-bottom: 0.5rem; overflow: hidden; }
        .install-accordion-item:last-child { margin-bottom: 0; }
        .install-accordion-header { padding: 0.75rem 1rem; font-weight: 600; font-size: 1rem; cursor: pointer; list-style: none; background: var(--bg-section, #f8f9fa); transition: background 0.2s ease; }
        .install-accordion-header::-webkit-details-marker { display: none; }
        .install-accordion-header::before { content: '▶'; display: inline-block; margin-right: 0.5rem; font-size: 0.7em; transition: transform 0.2s ease; }
        .install-accordion-item[open] .install-accordion-header::before { transform: rotate(90deg); }
        .install-accordion-header:hover { background: var(--bg-hover, #fafafa); }
        .install-accordion-body { padding: 1rem 1rem 1rem 2rem; border-top: 1px solid var(--border, #e5e5e5); }
        .skill-list { margin: 1rem 0 1rem 1.5rem; padding-left: 1.5rem; }
        .skill-list li { margin-bottom: 1.5rem; }
        .skill-list li:last-child { margin-bottom: 0; }
        .skill-summary { margin-top: 0.5rem; margin-left: 0; font-weight: 400; }
        .collection-mcp-grid { margin-top: 1rem; }
        .collection-mcp-card { text-decoration: none; color: inherit; display: block; cursor: pointer; }
    </style>
</head>
<body>
    <header>
        <div class="toolbar">
            <div class="toolbar-left">
                <a href="../index.html" class="collection-back">← Back to Catalog</a>
                <h1>{{ title }}</h1>
                <p class="subtitle">{{ subtitle }}</p>
            </div>
            <div class="toolbar-right">
                <a href="https://github.com/RHEcosystemAppEng/agentic-collections" target="_blank" class="toolbar-button">GitHub</a>
            </div>
        </div>
    </header>
    <main>
        <div class="collection-content">
            <nav class="collection-tabs" role="tablist">
                <button class="collection-tab active" role="tab" aria-selected="true" data-tab="overview">Overview</button>
                <button class="collection-tab" role="tab" aria-selected="false" data-tab="skills">Skills</button>
                <button class="collection-tab" role="tab" aria-selected="false" data-tab="resources">Resources</button>
                <button class="collection-tab" role="tab" aria-selected="false" data-tab="agents">Agents</button>
            </nav>

            <div id="tab-overview" class="collection-tab-panel active" role="tabpanel">
                {{ overview_html | safe }}
            </div>
            <div id="tab-skills" class="collection-tab-panel" role="tabpanel">
                {{ skills_html | safe }}
            </div>
            <div id="tab-resources" class="collection-tab-panel" role="tabpanel">
                {{ resources_html | safe }}
            </div>
            <div id="tab-agents" class="collection-tab-panel" role="tabpanel">
                {{ agents_html | safe }}
            </div>
        </div>
    </main>
    <footer>
        <p>Generated from <a href="https://github.com/RHEcosystemAppEng/agentic-collections" target="_blank">agentic-collections</a> repository</p>
    </footer>

    <!-- Modal for MCP Server Details (same as catalog) -->
    <div id="mcp-modal" class="modal">
        <div class="modal-content" id="mcp-details"></div>
    </div>

    <script src="../app.js?v=22"></script>
    <script>
        // Tab switching
        document.querySelectorAll('.collection-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                const targetId = 'tab-' + tab.dataset.tab;
                document.querySelectorAll('.collection-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
                document.querySelectorAll('.collection-tab-panel').forEach(p => p.classList.remove('active'));
                tab.classList.add('active');
                tab.setAttribute('aria-selected', 'true');
                document.getElementById(targetId).classList.add('active');
            });
        });
    </script>
</body>
</html>
